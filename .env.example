# ── Telegram Bot ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OCR API Base URL ──────────────────────────────────
# Set to the root URL of your FastAPI service (no trailing slash).
# The bot will call /parse-text (Paddle) and /parse-text-gemini (Gemini).
API_BASE_URL=http://localhost:8000

# Legacy fallback (used if API_BASE_URL is not set)
# OCR_API_URL=http://localhost:8000/parse-text

# ── Gemini API Credentials ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_MODEL_2=gemini-2.5-flash
GEMINI_API_KEY_3=your_gemini_api_key_3_here
GEMINI_MODEL_3=gemini-2.5-pro

# ── FastAPI Service Configuration ────────────────────
PORT=8000
POLL_INTERVAL=5
MAX_WAIT_SECONDS=300

# ── Google Sheets Configuration ───────────────────────
GOOGLE_SHEETS_NAME=OCR_EQ_PARSER
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
